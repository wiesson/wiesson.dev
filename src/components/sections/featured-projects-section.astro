---
import type { Locale } from "../../i18n";
import { getTranslations } from "../../i18n";
import { getCollection } from "astro:content";

interface Props {
  lang?: Locale;
}

const { lang = "de" } = Astro.props;
const t = getTranslations(lang);

// Get work collection based on language
const collectionName = lang === "de" ? "work" : "work-en";
const projectsCollectionName = lang === "de" ? "projects" : "projects-en";
const allWork = await getCollection(collectionName);
const allProjects = await getCollection(projectsCollectionName);

// Map project slugs to their status
const projectStatusMap: Record<string, string> = {};
for (const proj of allProjects) {
  projectStatusMap[proj.id] = proj.data.status || "live";
}

// Filter for specific featured projects
const featuredSlugs = ["kuvio", "maklerupdate", "easy-invoice", "tourvy"];
const featuredProjects = allWork.filter((item) => {
  const slug = item.id.toLowerCase();
  const projectName = item.data.project?.toLowerCase() || "";
  return featuredSlugs.some(
    (featured) =>
      slug.includes(featured) ||
      projectName.includes(featured) ||
      (featured === "easy-invoice" && projectName.includes("kontor"))
  );
});

// Sort by most recent
featuredProjects.sort((a, b) => {
  const dateA = a.data.from.getTime();
  const dateB = b.data.from.getTime();
  return dateB - dateA;
});

// Deduplicate by project name (keep most recent)
const uniqueProjects: typeof featuredProjects = [];
const seenProjects = new Set<string>();
for (const project of featuredProjects) {
  const projectName = project.data.project?.toLowerCase() || "";
  const key = featuredSlugs.find(
    (s) => projectName.includes(s) || project.id.includes(s) || (s === "easy-invoice" && projectName.includes("kontor"))
  );
  if (key && !seenProjects.has(key)) {
    seenProjects.add(key);
    uniqueProjects.push(project);
  }
}

// Project URLs
const projectUrls: Record<string, string | null> = {
  kuvio: "https://kuvio.studio",
  maklerupdate: "https://maklerupdate.de",
  "easy-invoice": "https://getkontor.app",
  tourvy: "https://tourvy.com",
};

// Status labels
const statusLabels: Record<string, { de: string; en: string }> = {
  live: { de: "Live", en: "Live" },
  beta: { de: "Beta", en: "Beta" },
  mvp: { de: "MVP", en: "MVP" },
  "in-development": { de: "In Entwicklung", en: "In Development" },
  archived: { de: "Archiviert", en: "Archived" },
  "coming-soon": { de: "Bald", en: "Soon" },
};
---

<section class="app-grid py-12">
  <div class="app-text-column-left">
    <h2 class="title mb-6">{t.sections.featuredProjects}</h2>
    <div class="space-y-4">
      {
        uniqueProjects.slice(0, 4).map((project) => {
          const slug = featuredSlugs.find(
            (s) =>
              project.data.project?.toLowerCase().includes(s) ||
              project.id.includes(s)
          );
          const externalUrl = slug ? projectUrls[slug] : undefined;
          const projectStatus = slug ? projectStatusMap[slug] : null;
          const statusLabel = projectStatus ? statusLabels[projectStatus]?.[lang] : null;
          return (
            <div class="p-4 rounded-lg border border-border bg-card">
              <div class="flex items-center justify-between gap-2 mb-2">
                <h3 class="font-semibold text-foreground">
                  {project.data.project}
                </h3>
                <div class="flex items-center gap-2 shrink-0">
                  {statusLabel && projectStatus && (
                    <span class={`cv-badge cv-badge-${projectStatus} text-[10px]`}>
                      {statusLabel}
                    </span>
                  )}
                  {externalUrl && (
                    <a
                      href={externalUrl}
                      target="_blank"
                      rel="noopener"
                      class="text-muted-foreground hover:text-foreground transition-colors"
                      aria-label={`Visit ${project.data.project}`}
                    >
                      <svg
                        class="w-4 h-4"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
                        />
                      </svg>
                    </a>
                  )}
                </div>
              </div>
              {project.data.intro && (
                <p class="text-sm text-muted-foreground">
                  {project.data.intro}
                </p>
              )}
            </div>
          );
        })
      }
    </div>
  </div>
</section>
