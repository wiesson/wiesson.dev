---
import TrendingUp from '@lucide/astro/icons/trending-up';
import Badge from '$components/ui/badge.astro';
import type { Example } from "$data/services";

interface Props {
  examples: Example[];
  title?: string;
  description?: string;
}

const { examples, title = "Beispiel-Projekte", description } = Astro.props;
---

<section class="app-grid py-20" style="background-color: var(--muted);">
  <div class="app-text-column mb-12 text-center">
    <h2 class="heading mb-2">{title}</h2>
    {description && <p class="text-muted-foreground">{description}</p>}
  </div>

  <div class="app-wide-column">
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {examples.map((example) => (
        <div class="bg-card text-card-foreground flex flex-col gap-6 rounded-xl border py-6 shadow-sm">
          <div class="grid auto-rows-min grid-rows-[auto_auto] items-start gap-1.5 px-6">
            <div class="font-semibold leading-none text-lg">{example.title}</div>
            <p class="text-muted-foreground text-sm mt-2">{example.description}</p>
          </div>
          <div class="px-6 flex-1 flex flex-col justify-between">
            <div class="mb-4">
              <p class="mb-2 text-xs font-semibold uppercase text-muted-foreground">
                Tech Stack
              </p>
              <div class="flex flex-wrap gap-2">
                {example.tech.map((tech) => (
                  <Badge variant="secondary" class="text-xs">{tech}</Badge>
                ))}
              </div>
            </div>
            {example.results && (
              <div class="rounded-lg bg-primary/5 p-3 border border-primary/20">
                <div class="flex items-start gap-2">
                  <TrendingUp class="size-4 text-primary mt-0.5 flex-shrink-0" />
                  <p class="text-sm font-medium text-primary">
                    {example.results}
                  </p>
                </div>
              </div>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
