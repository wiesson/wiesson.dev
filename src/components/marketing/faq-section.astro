---
import type { FAQ } from "$data/services";

interface Props {
  faqs: FAQ[];
  title?: string;
  description?: string;
}

const { faqs, title = "Häufige Fragen", description } = Astro.props;
---

<section class="app-grid py-20" style="background-color: var(--muted);">
  <div class="app-text-column mb-12 text-center">
    <h2 class="heading mb-2">{title}</h2>
    {description && <p class="text-muted-foreground">{description}</p>}
  </div>

  <div class="app-text-column">
    <div class="w-full divide-y divide-border">
      {faqs.map((faq) => (
        <details name="faq" class="group">
          <summary class="flex w-full cursor-pointer items-center justify-between py-4 text-left font-medium transition-all hover:underline">
            <span>{faq.q}</span>
            <svg
              class="size-4 shrink-0 text-muted-foreground transition-transform duration-200 group-open:rotate-180"
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="m6 9 6 6 6-6" />
            </svg>
          </summary>
          <div class="pb-4 pt-0">
            <p class="text-muted-foreground">{faq.a}</p>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>
