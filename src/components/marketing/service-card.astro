---
import Bot from '@lucide/astro/icons/bot';
import Database from '@lucide/astro/icons/database';
import Layers from '@lucide/astro/icons/layers';
import Award from '@lucide/astro/icons/award';
import CircleCheck from '@lucide/astro/icons/circle-check';
import ArrowRight from '@lucide/astro/icons/arrow-right';
import Badge from '$components/ui/badge.astro';
import Button from '$components/ui/button.astro';

const iconMap: Record<string, any> = { bot: Bot, database: Database, layers: Layers, award: Award };

interface Props {
  title: string;
  description: string;
  price: string;
  features: string[];
  href: string;
  icon: string;
  badge?: string;
}

const { title, description, price, features, href, icon, badge } = Astro.props;
const IconComponent = iconMap[icon];
---

<div class="bg-card text-card-foreground flex flex-col gap-6 rounded-xl border py-6 shadow-sm h-full">
  <div class="grid auto-rows-min grid-rows-[auto_auto] items-start gap-1.5 px-6">
    <div class="mb-4 flex size-12 items-center justify-center rounded-lg bg-primary/10">
      {IconComponent && <IconComponent class="size-6 text-primary" />}
    </div>
    {badge && (
      <div class="mb-2">
        <Badge variant="default">{badge}</Badge>
      </div>
    )}
    <div class="mb-2">
      <Badge variant="outline" class="text-xs">{price}</Badge>
    </div>
    <div class="font-semibold leading-none text-xl">{title}</div>
    <p class="text-muted-foreground text-sm">{description}</p>
  </div>
  <div class="px-6 flex-1 flex flex-col">
    <ul class="space-y-2 mb-6 flex-1">
      {features.map((feature) => (
        <li class="flex items-start gap-2 text-sm text-muted-foreground">
          <CircleCheck class="mt-0.5 size-4 flex-shrink-0 text-primary" />
          <span>{feature}</span>
        </li>
      ))}
    </ul>
    <Button href={href} class="w-full">
      Details ansehen
      <ArrowRight class="ml-2 size-4" />
    </Button>
  </div>
</div>
